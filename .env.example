# Shared
NODE_ENV=development

# API
API_PORT=4000
DATABASE_URL=postgresql://taskbridge:taskbridge@localhost:5432/taskbridge
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000
# Base URL for invite links returned by POST /v1/workspaces/:id/invitations (optional; defaults to http://localhost:3000)
PUBLIC_WEB_URL=http://localhost:3000
AGENT_INGEST_PEPPER=replace_me_agent_ingest_pepper

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
